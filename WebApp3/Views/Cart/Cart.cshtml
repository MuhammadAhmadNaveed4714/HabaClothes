@model List<CartItem>

<h2>🛒 My Shopping Cart</h2>

@if (TempData["Message"] != null)
{
    <div class="alert alert-success">@TempData["Message"]</div>
}

@if (!Model.Any())
{
    <p>Your cart is empty.</p>
}
else
{
    <table class="table">
        <tr>
            <th>Product</th>
            <th>Price</th>
            <th>Qty</th>
            <th>Total</th>
            <th>Action</th>
        </tr>

        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Name</td>

                <!-- ✅ Rs instead of $ -->
                <td>Rs @item.Price</td>

                <td>@item.Quantity</td>

                <!-- ✅ Rs instead of $ -->
                <td>Rs @(item.Price* item.Quantity)</td>

                <td>
                    <a asp-action="Remove" asp-route-id="@item.ProductId"
                       class="btn btn-danger btn-sm">Remove</a>
                </td>
            </tr>
        }
    </table>
}

@{
    var phoneNumber = "923195878476";

    var message = "Order Details:%0A";

    foreach (var item in Model)
    {
        // ✅ Rs instead of $
        message += $"{item.Name} (Qty: {item.Quantity}) - Rs {item.Price * item.Quantity}%0A";
    }

    var total = Model.Sum(x => x.Price * x.Quantity);

    // already Rs tha 👍
    message += $"%0ATotal: Rs {total}";
}

@if (Model.Any())
{
    <div class="mt-3">
        <a asp-action="ClearCart" class="btn btn-warning">Clear Cart</a>

        <a href="https://wa.me/@(phoneNumber)?text=@(message)"
           target="_blank"
           class="btn btn-success ms-2">
            📦 Order Now
        </a>
    </div>
}