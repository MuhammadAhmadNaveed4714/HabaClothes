@model List<Product>

@{
    ViewData["Title"] = "Products";
}

<h2 class="mb-4">🛍️ Our Products</h2>

<div class="row">

    @foreach (var item in Model)
    {
        <div class="col-md-4 mb-4">
            <div class="card h-100 shadow-sm">

               
                <img src="@item.FrontImageUrl" class="card-img-top" style="height:200px; object-fit:cover;" />

                <div class="card-body d-flex flex-column">

                    <h5 class="card-title">@item.Name</h5>

                    <p class="text-warning">⭐⭐⭐⭐⭐</p>

                    <p class="card-text text-success fw-bold d-flex justify-content-between align-items-center">
                        <span>$@item.Price</span>

                        <a asp-controller="Product" asp-action="Details" asp-route-id="@item.Id"
                           class="btn btn-sm btn-outline-primary">
                            Details
                        </a>
                    </p>

                    <a asp-controller="Cart" asp-action="AddToCart" asp-route-id="@item.Id"
                       class="btn btn-warning mt-auto">
                        🛒 Add to Cart
                    </a>

                </div>
            </div>
        </div>
    }

</div>
