@{
    ViewData["Title"] = "Home";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">

    <!-- Hero Section -->
    <div class="text-center mb-5">
        <h1 class="display-4 fw-bold">👕 Welcome to Haba Clothes</h1>
        <p class="lead">
            Premium quality children's wear at affordable prices.
            Stylish outfits for kids aged <strong>3–4 to 12–14 years</strong>.
        </p>

        <a asp-controller="Product" asp-action="Index" class="btn btn-warning btn-lg mt-3">
            🛍️ Shop Now
        </a>
    </div>

    <!-- Slideshow -->
    <div id="sliderContainer" class="mb-5" style="width:100%; max-width:500px; margin:auto; position:relative;">
        <img id="slideImage" src="/images/pict1.jpg"
             class="slider-img rounded shadow" />

        <!-- Dots Indicators -->
        <div id="dotsContainer" style="position:absolute; bottom:10px; width:100%; text-align:center;">
            <!-- Dots will be generated by JS -->
        </div>
    </div>

    <!-- Info Section -->
    <div class="row text-center mt-5">
        <div class="col-md-4">
            <div class="card p-4 shadow-sm home-card">
                <h4>✨ Premium Quality</h4>
                <p>We use high-quality fabrics to ensure comfort and durability for kids.</p>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card p-4 shadow-sm home-card">
                <h4>💰 Affordable Prices</h4>
                <p>Trendy and stylish clothes at prices everyone can afford.</p>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card p-4 shadow-sm home-card">
                <h4>🚚 Easy Ordering</h4>
                <p>Order online easily and get your favorite outfits delivered to your door.</p>
            </div>
        </div>
    </div>

</div>

<!-- CSS -->
<style>
    .home-card {
        border-radius: 15px;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

        .home-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 10px 25px rgba(0,0,0,0.2);
        }

    /* Slideshow */
    .slider-img {
        width: 100%;
        aspect-ratio: 1/1; /* square */
        object-fit: cover;
        display: block;
        margin: auto;
    }

    .dot {
        height: 12px;
        width: 12px;
        margin: 0 5px;
        display: inline-block;
        border-radius: 50%;
        background-color: #ddd;
        cursor: pointer;
        transition: background-color 0.3s;
    }

        .dot.active {
            background-color: #ffc107;
        }
</style>

<!-- JS Slideshow -->
<script>
    var images = [
         "/images/pict1.jpg",
         "/images/pict3.jpg",
         "/images/pict5.jpg"
     ];

    var index = 0;
    var slideImage = document.getElementById("slideImage");
    var dotsContainer = document.getElementById("dotsContainer");

    // Create dots dynamically
    for (var i = 0; i < images.length; i++) {
        var dot = document.createElement("span");
        dot.className = "dot";
        dot.setAttribute("data-index", i);
        dot.onclick = function() {
            index = parseInt(this.getAttribute("data-index"));
            showSlide(index);
        };
        dotsContainer.appendChild(dot);
    }

    function showSlide(idx) {
        slideImage.src = images[idx];
        updateDots(idx);
    }

    function updateDots(idx) {
        var dots = document.querySelectorAll("#dotsContainer .dot");
        dots.forEach(function(d, i){
            d.classList.toggle("active", i === idx);
        });
    }

    // Initial display
    showSlide(index);

    // Auto slideshow every 3 seconds
    setInterval(function(){
        index = (index + 1) % images.length;
        showSlide(index);
    }, 3000);
</script>